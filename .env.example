# ── Wallet ──────────────────────────────────────────────────────────────
# Your Ethereum/Polygon wallet private key (with or without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Optional: the address that actually holds your USDC on Polymarket.
# Find it on your polymarket.com profile page — it's usually NOT the same
# address as your raw wallet/MetaMask address.
# If you signed up with just an email/magic-link, leave blank only if that
# address matches your wallet; otherwise put the deposit address here.
# If you connected a browser wallet (MetaMask, etc.), Polymarket created a
# Gnosis Safe for you — put that Safe's address here.
POLY_PROXY_ADDRESS=

# How POLY_PROXY_ADDRESS above should be treated. Only matters if it's set.
#   GNOSIS_SAFE (default) — browser-wallet signups (MetaMask, etc.)
#   PROXY                 — email/magic-link signups
#   DEPOSIT_WALLET         — post-V2 accounts (signature_type 3 / POLY_1271).
#                            Balance reads use a raw HTTP call since the SDK has
#                            no enum value for this yet; order placement is NOT
#                            implemented for this type.
POLY_SIGNATURE_TYPE=GNOSIS_SAFE

# ── API credentials (run: npm run setup to auto-generate) ────────────────
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ── Safety guard ─────────────────────────────────────────────────────────
# Set to 'true' ONLY when you are ready to spend real USDC.
# Leave as 'false' to run in simulation (logs orders, never posts them).
LIVE_MODE=false

# ── Trade configuration ───────────────────────────────────────────────────
# Only enter when YES + NO combined < this. spiralgalaxy hit as low as 0.54.
# Start at 0.85, lower gradually once confident.
COMBINED_THRESHOLD=0.85

# Max USDC per market (both sides combined)
MAX_TRADE_USDC=100

DANGER_PRICE=0.15
SELL_OPPOSITE_ABOVE=0.84

# ── Copy-trade bot (npm run copy) ─────────────────────────────────────────
# Comma-separated wallet addresses to watch and copy
WATCH_WALLETS=0x8fbd7cf5f806f563080864694415829f7229a959

# How often to poll for new positions (minutes). 10 is fine for daily weather markets.
COPY_POLL_MIN=10

# USDC to spend per copied trade
COPY_BET_USDC=20

# Skip markets resolving in less than this many hours
COPY_MIN_HOURS=2
